# Application
APP_ENV=development
SECRET_KEY=change-me-to-a-32-char-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Database (Docker local — override for Azure PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/cloudlabs

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_SUMMARY_DEPLOYMENT=gpt-4.1

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<your-search-api-key>
AZURE_SEARCH_INDEX_NAME=cloudlabs-knowledge

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=knowledge-base

# Azure Key Vault (optional — production)
AZURE_KEY_VAULT_URL=https://<your-vault>.vault.azure.net/

# CORS
FRONTEND_URL=http://localhost:3000

# Redis
REDIS_URL=redis://redis:6379
